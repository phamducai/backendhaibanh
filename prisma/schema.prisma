generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model blog_categories {
  id                          String                        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                        String                        @db.VarChar(100)
  slug                        String                        @unique @db.VarChar(100)
  blog_category_relationships blog_category_relationships[]
}

model blog_category_relationships {
  post_id         String          @db.Uuid
  category_id     String          @db.Uuid
  blog_categories blog_categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  blog_posts      blog_posts      @relation(fields: [post_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([post_id, category_id])
}

model blog_posts {
  id                          String                        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title                       String                        @db.VarChar(255)
  slug                        String                        @unique @db.VarChar(255)
  content                     String
  author_id                   String                        @db.Uuid
  thumbnail_url               String?
  status                      post_status                   @default(DRAFT)
  view_count                  Int?                          @default(0)
  created_at                  DateTime?                     @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime?                     @default(now()) @db.Timestamptz(6)
  is_featured                 Boolean?                      @default(false)
  blog_category_relationships blog_category_relationships[]
  users                       users                         @relation(fields: [author_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([author_id], map: "idx_blog_posts_author_id")
  @@index([slug], map: "idx_blog_posts_slug")
  @@index([status], map: "idx_blog_posts_status")
}

model content_tags {
  content_type String @db.VarChar(20)
  content_id   String @db.Uuid
  tag_id       String @db.Uuid
  tags         tags   @relation(fields: [tag_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([content_type, content_id, tag_id])
}

model course_lessons {
  id                String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  module_id         String              @db.Uuid
  title             String              @db.VarChar(255)
  description       String?
  order             Int
  content_type      content_type
  youtube_video_id  String?             @db.VarChar(20)
  video_title       String?             @db.VarChar(255)
  video_filename    String?             @db.VarChar(255)
  duration_seconds  Int?
  document_url      String?
  is_free_preview   Boolean?            @default(false)
  created_at        DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime?           @default(now()) @db.Timestamptz(6)
  course_modules    course_modules      @relation(fields: [module_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  progress_tracking progress_tracking[]
  video_comments    video_comments[]

  @@index([module_id], map: "idx_course_lessons_module_id")
  @@index([youtube_video_id], map: "idx_course_lessons_youtube_id")
}

model course_modules {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  course_id      String           @db.Uuid
  title          String           @db.VarChar(255)
  description    String?
  order          Int
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  course_lessons course_lessons[]
  courses        courses          @relation(fields: [course_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([course_id], map: "idx_course_modules_course_id")
}

model courses {
  id             String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title          String           @db.VarChar(255)
  slug           String           @unique @db.VarChar(255)
  description    String?
  price          Decimal          @db.Decimal(10, 2)
  discount_price Decimal?         @db.Decimal(10, 2)
  instructor_id  String           @db.Uuid
  thumbnail_url  String?
  level          course_level
  duration_hours Int?
  is_published   Boolean?         @default(false)
  created_at     DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?        @default(now()) @db.Timestamptz(6)
  course_modules course_modules[]
  users          users            @relation(fields: [instructor_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  enrollments    enrollments[]

  @@index([instructor_id], map: "idx_courses_instructor_id")
  @@index([slug], map: "idx_courses_slug")
}

model enrollments {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id             String              @db.Uuid
  course_id           String              @db.Uuid
  purchased_at        DateTime?           @default(now()) @db.Timestamptz(6)
  price_paid          Decimal             @db.Decimal(10, 2)
  payment_id          String?             @db.Uuid
  is_completed        Boolean?            @default(false)
  progress_percentage Int?                @default(0)
  courses             courses             @relation(fields: [course_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  payments            payments?           @relation(fields: [payment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users               users               @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  progress_tracking   progress_tracking[]

  @@unique([user_id, course_id])
  @@index([course_id], map: "idx_enrollments_course_id")
  @@index([user_id], map: "idx_enrollments_user_id")
}

model payment_providers {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name       String    @unique @db.VarChar(50)
  api_key    String?
  api_secret String?
  is_active  Boolean?  @default(true)
  config     Json?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}

model payments {
  id                 String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id            String               @db.Uuid
  amount             Decimal              @db.Decimal(10, 2)
  currency           String?              @default("VND") @db.VarChar(3)
  status             payment_status       @default(PENDING)
  payment_method     String?              @db.VarChar(50)
  transaction_id     String?              @db.VarChar(255)
  provider           String?              @db.VarChar(50)
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at         DateTime?            @default(now()) @db.Timestamptz(6)
  product_type       product_type
  product_id         String               @db.Uuid
  enrollments        enrollments[]
  users              users                @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  template_purchases template_purchases[]

  @@index([status], map: "idx_payments_status")
  @@index([user_id], map: "idx_payments_user_id")
}

model progress_tracking {
  id                    String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  enrollment_id         String         @db.Uuid
  lesson_id             String         @db.Uuid
  is_completed          Boolean?       @default(false)
  completed_at          DateTime?      @db.Timestamptz(6)
  last_position_seconds Int?           @default(0)
  created_at            DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?      @default(now()) @db.Timestamptz(6)
  enrollments           enrollments    @relation(fields: [enrollment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  course_lessons        course_lessons @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([enrollment_id, lesson_id])
  @@index([enrollment_id], map: "idx_progress_tracking_enrollment_id")
  @@index([lesson_id], map: "idx_progress_tracking_lesson_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model reviews {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String    @db.Uuid
  content_type String    @db.VarChar(10)
  content_id   String    @db.Uuid
  rating       Int
  comment      String?
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  users        users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, content_type, content_id])
  @@index([content_type, content_id], map: "idx_reviews_content_type_content_id")
}

model sessions {
  id         String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id    String    @db.Uuid
  token      String
  expires_at DateTime  @db.Timestamptz(6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expires_at], map: "idx_sessions_expires_at")
  @@index([user_id], map: "idx_sessions_user_id")
}

model tags {
  id           String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name         String         @unique @db.VarChar(50)
  slug         String         @unique @db.VarChar(50)
  content_tags content_tags[]
}

model template_categories {
  id                              String                            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                            String                            @db.VarChar(100)
  slug                            String                            @unique @db.VarChar(100)
  template_category_relationships template_category_relationships[]
}

model template_category_relationships {
  template_id         String              @db.Uuid
  category_id         String              @db.Uuid
  template_categories template_categories @relation(fields: [category_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  templates           templates           @relation(fields: [template_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([template_id, category_id])
}

model template_purchases {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id      String    @db.Uuid
  template_id  String    @db.Uuid
  purchased_at DateTime? @default(now()) @db.Timestamptz(6)
  price_paid   Decimal   @db.Decimal(10, 2)
  payment_id   String?   @db.Uuid
  payments     payments? @relation(fields: [payment_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  templates    templates @relation(fields: [template_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users        users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([user_id, template_id])
  @@index([template_id], map: "idx_template_purchases_template_id")
  @@index([user_id], map: "idx_template_purchases_user_id")
}

model templates {
  id                              String                            @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title                           String                            @db.VarChar(255)
  slug                            String                            @unique @db.VarChar(255)
  description                     String?
  price                           Decimal                           @db.Decimal(10, 2)
  author_id                       String                            @db.Uuid
  preview_url                     String?
  download_url                    String?
  json_data                       Json?
  compatibility_version           String?                           @db.VarChar(50)
  is_published                    Boolean?                          @default(false)
  created_at                      DateTime?                         @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime?                         @default(now()) @db.Timestamptz(6)
  template_category_relationships template_category_relationships[]
  template_purchases              template_purchases[]
  users                           users                             @relation(fields: [author_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([author_id], map: "idx_templates_author_id")
  @@index([slug], map: "idx_templates_slug")
}

model users {
  id                 String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email              String               @unique @db.VarChar(255)
  full_name          String               @db.VarChar(255)
  google_id          String?              @unique @db.VarChar(255)
  role               user_role            @default(STUDENT)
  avatar_url         String?
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  last_login         DateTime?            @db.Timestamptz(6)
  pass_word          String?
  blog_posts         blog_posts[]
  courses            courses[]
  enrollments        enrollments[]
  payments           payments[]
  reviews            reviews[]
  sessions           sessions[]
  template_purchases template_purchases[]
  templates          templates[]
  video_comments     video_comments[]

  @@index([email], map: "idx_users_email")
  @@index([google_id], map: "idx_users_google_id")
}

model video_comments {
  id                   String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  lesson_id            String           @db.Uuid
  user_id              String           @db.Uuid
  comment              String
  timestamp_seconds    Int?
  parent_id            String?          @db.Uuid
  created_at           DateTime?        @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?        @default(now()) @db.Timestamptz(6)
  course_lessons       course_lessons   @relation(fields: [lesson_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  video_comments       video_comments?  @relation("video_commentsTovideo_comments", fields: [parent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_video_comments video_comments[] @relation("video_commentsTovideo_comments")
  users                users            @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([lesson_id], map: "idx_video_comments_lesson_id")
  @@index([user_id], map: "idx_video_comments_user_id")
}

enum content_type {
  VIDEO
  DOCUMENT
  EXERCISE
}

enum course_level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum payment_status {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum post_status {
  DRAFT
  PUBLISHED
}

enum product_type {
  COURSE
  TEMPLATE
}

enum user_role {
  ADMIN
  INSTRUCTOR
  STUDENT
}
